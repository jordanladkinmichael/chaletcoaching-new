# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"

# NextAuth
NEXTAUTH_URL="https://your-domain.vercel.app"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# OpenAI
OPENAI_API_KEY="sk-..."

# Resend (Email Service)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Chaletcoaching <info@chaletcoaching.co.uk>"

# Inngest (Background Jobs / Queue)
INNGEST_EVENT_KEY="your-inngest-event-key"
INNGEST_SIGNING_KEY="signkey-..."

# Vercel Blob Storage (для хранения PDF файлов)
BLOB_READ_WRITE_TOKEN="vercel_blob_xxx"

# Payment System
# PAYMENT_PROVIDER="paypal|razorpay|custom"
# PAYMENT_SECRET_KEY="your-payment-secret"
# PAYMENT_PUBLISHABLE_KEY="your-payment-publishable"
# PAYMENT_WEBHOOK_SECRET="your-webhook-secret"

# CardServ payment gateway
PAYMENT_PROVIDER="cardserv"
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
CARDSERV_MODE="live"
CARDSERV_BASE_URL="https://live.cardserv.io"
CARDSERV_REQUESTOR_ID="your-default-requestor-id"
CARDSERV_TOKEN="bt_..."
CARDSERV_EUR_REQUESTOR_ID="your-eur-requestor-id"
CARDSERV_EUR_TOKEN="bt_..."
CARDSERV_GBP_REQUESTOR_ID="your-gbp-requestor-id"
CARDSERV_GBP_TOKEN="bt_..."
CARDSERV_USD_REQUESTOR_ID="your-usd-requestor-id"
CARDSERV_USD_TOKEN="bt_..."

# Non-production only: simulate approved payment and immediate token credit.
PAYMENTS_FORCE_SUCCESS="false"
